// test_network_interface.act — Testbench for the NI
//
// Import the network interface source file.
// We instantiate the NI at local coordinates X=1, Y=1.
// MESH_LENGTH = 2 (for a 4x4 mesh), DATA_WIDTH = 8.
// Total packet size: 2(2) + 2 + 8 = 14 bits.

import "src/network_interface.act"; 

defproc test_ni_ctrl (
    // Channels to test Injection (TX)
    chan!(int<14>)  test_to_core_in;
    chan?(int<14>)  test_from_router_out;

    // Channels to test Ejection (RX)
    chan!(int<14>)  test_to_router_in;
    chan?(int<14>)  test_from_core_out
)
{
    int<14> raw_pkt;     // Packet generated by "Core" to send
    int<14> pkt;         // Packet received from "Router" TX output
    
    int<14> mock_rx_pkt; // Mock packet arriving from "Router"
    int<14> ejected_pkt; // Packet ejected to "Core"

    // Variables to unpack the packet for easy reading in the log
    int<2> res_x, res_y;
    int<1> res_x_dir, res_y_dir;
    int<8> res_data;

    chp {
        // =========================================================
        // PART 1: INJECTION TESTS (Core -> NI -> Router)
        // =========================================================

        // ---------------------------------------------------------
        // 1. Test moving East and North (+X, +Y)
        // Current: (1,1). Dest: (3,3). Data: 0xAA (170)
        // ---------------------------------------------------------
        // Package the raw packet. Direction bits (9..8) are left as 0.
        raw_pkt{13..12} := 3; raw_pkt{11..10} := 3; raw_pkt{9..8} := 0; raw_pkt{7..0} := 0xAA;
        
        test_to_core_in!raw_pkt;
        test_from_router_out?pkt;
        
        res_x := pkt{13..12};
        res_y := pkt{11..10};
        res_x_dir := pkt{9};
        res_y_dir := pkt{8};
        res_data := pkt{7..0};
        log("TEST 1 (+X, +Y):");
        log("  Expected: Dest(3,3) | x_dir:1 y_dir:1 | data: 170");
        log("  Actual  : Dest(", res_x, ",", res_y, ") | x_dir:", res_x_dir, " y_dir:", res_y_dir, " | data: ", res_data);

        // ---------------------------------------------------------
        // 2. Test moving West and South (-X, -Y)
        // Current: (1,1). Dest: (0,0). Data: 0x55 (85)
        // ---------------------------------------------------------
        raw_pkt{13..12} := 0; raw_pkt{11..10} := 0; raw_pkt{9..8} := 0; raw_pkt{7..0} := 0x55;
        
        test_to_core_in!raw_pkt;
        test_from_router_out?pkt;
        
        res_x := pkt{13..12};
        res_y := pkt{11..10};
        res_x_dir := pkt{9};
        res_y_dir := pkt{8};
        res_data := pkt{7..0};
        log("TEST 2 (-X, -Y):");
        log("  Expected: Dest(0,0) | x_dir:0 y_dir:0 | data: 85");
        log("  Actual  : Dest(", res_x, ",", res_y, ") | x_dir:", res_x_dir, " y_dir:", res_y_dir, " | data: ", res_data);

        // ---------------------------------------------------------
        // 3. Test same X, moving North (0, +Y)
        // Current: (1,1). Dest: (1,3). Data: 0xFF (255)
        // ---------------------------------------------------------
        raw_pkt{13..12} := 1; raw_pkt{11..10} := 3; raw_pkt{9..8} := 0; raw_pkt{7..0} := 0xFF;
        
        test_to_core_in!raw_pkt;
        test_from_router_out?pkt;
        
        res_x := pkt{13..12};
        res_y := pkt{11..10};
        res_x_dir := pkt{9};
        res_y_dir := pkt{8};
        res_data := pkt{7..0};
        log("TEST 3 ( 0, +Y):");
        log("  Expected: Dest(1,3) | x_dir:0 y_dir:1 | data: 255");
        log("  Actual  : Dest(", res_x, ",", res_y, ") | x_dir:", res_x_dir, " y_dir:", res_y_dir, " | data: ", res_data);

        // ---------------------------------------------------------
        // 4. Test Local Arrival (Dest == Current Coord)
        // Current: (1,1). Dest: (1,1). Data: 0x00 (0)
        // ---------------------------------------------------------
        raw_pkt{13..12} := 1; raw_pkt{11..10} := 1; raw_pkt{9..8} := 0; raw_pkt{7..0} := 0x00;
        
        test_to_core_in!raw_pkt;
        test_from_router_out?pkt;
        
        res_x := pkt{13..12};
        res_y := pkt{11..10};
        res_x_dir := pkt{9};
        res_y_dir := pkt{8};
        res_data := pkt{7..0};
        log("TEST 4 (LOCAL) :");
        log("  Expected: Dest(1,1) | x_dir:0 y_dir:0 | data: 0");
        log("  Actual  : Dest(", res_x, ",", res_y, ") | x_dir:", res_x_dir, " y_dir:", res_y_dir, " | data: ", res_data);


        // =========================================================
        // PART 2: EJECTION TESTS (Router -> NI -> Core)
        // =========================================================

        // ---------------------------------------------------------
        // 5. Test Receiving from Network
        // Mock a packet arriving from the router. Dest: (1,1), Data: 0xBB (187)
        // ---------------------------------------------------------
        mock_rx_pkt{13..12} := 1; mock_rx_pkt{11..10} := 1; mock_rx_pkt{9..8} := 0; mock_rx_pkt{7..0} := 0xBB;
        
        test_to_router_in!mock_rx_pkt;
        test_from_core_out?ejected_pkt;

        res_x := ejected_pkt{13..12};
        res_y := ejected_pkt{11..10};
        res_data := ejected_pkt{7..0};
        
        log("TEST 5 (EJECTION):");
        log("  Expected: Dest(1,1) | data: 187"); 
        log("  Actual  : Dest(", res_x, ",", res_y, ") | data: ", res_data);

        log("All Network Interface test cases complete!")
    }
}

// Top-level instantiation
defproc test_ni ()
{
    // 14-bit standardized channels
    chan(int<14>) core_in_chan;
    chan(int<14>) router_out_chan;
    chan(int<14>) router_in_chan;
    chan(int<14>) core_out_chan; 
    
    // Instantiate the Network Interface (Current location: X=1, Y=1)
    network_interface<2, 8, 1, 1> dut(
        core_in_chan, 
        router_out_chan, 
        router_in_chan, 
        core_out_chan
    );
    
    // Instantiate the Testbench Controller
    test_ni_ctrl ctrl(
        core_in_chan, 
        router_out_chan, 
        router_in_chan, 
        core_out_chan
    );
}